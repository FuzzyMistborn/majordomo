# ── Required ──────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Comma-separated list of Telegram user IDs allowed to use the bot
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321

# Tavily Search API key — https://app.tavily.com/home (free tier: 1000 queries/month)
TAVILY_API_KEY=your-tavily-api-key-here

# Kagi Search API key — https://kagi.com/settings?p=api

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of your Ollama instance (use host.docker.internal if Ollama runs on the host)
OLLAMA_HOST=http://host.docker.internal:11434

# Model to use — must support tool calling (gemma3:4b, llama3.1, qwen2.5, etc.)
OLLAMA_MODEL=gemma3:4b

# ── Home Assistant (optional — leave blank to disable) ────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-ha-token-here

# Comma-separated list of HA domains the bot is allowed to control
HA_ALLOWED_DOMAINS=light,switch,input_boolean,script,automation,climate,cover,fan,media_player

# ── CalDAV (optional — leave blank to disable) ────────────────────────────────
# CalDAV server URL — for Nextcloud: https://nextcloud.example.com/remote.php/dav
CALDAV_URL=https://nextcloud.example.com/remote.php/dav
CALDAV_USERNAME=your-nextcloud-username
# Use an app password from Nextcloud Settings → Security → App passwords
CALDAV_PASSWORD=your-app-password
# Comma-separated list of calendar display names to sync (leave blank for all calendars)
CALDAV_CALENDARS=Personal,Family

# Weather entity ID to use for current conditions and forecast (leave blank to disable)
HA_WEATHER_ENTITY=weather.home

# ── Bot settings ──────────────────────────────────────────────────────────────
# Timezone for reminders — use IANA names, e.g. America/New_York, Europe/London
TIMEZONE=UTC

# Number of messages to keep in conversation history per user
HISTORY_WINDOW=20
